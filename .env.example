# App
NODE_ENV=production
PORT=4000
APP_URL=https://app.fitgenie.ai

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/fitgenie

# Auth
JWT_SECRET=replace_with_long_random_secret
JWT_EXPIRES_IN=7d

# AI
LLM_API_KEY=replace_me
LLM_MODEL=gpt-4.1-mini
LLM_TIMEOUT_MS=20000

# Storage
S3_ENDPOINT=https://s3.amazonaws.com
S3_BUCKET=fitgenie-assets
S3_ACCESS_KEY=replace_me
S3_SECRET_KEY=replace_me

# Observability
LOG_LEVEL=info
SENTRY_DSN=
