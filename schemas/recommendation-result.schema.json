{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RecommendationResult",
  "type": "object",
  "required": ["userId", "recommendations", "confidenceScore"],
  "properties": {
    "userId": { "type": "string" },
    "confidenceScore": { "type": "number", "minimum": 0, "maximum": 1 },
    "recommendations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["outfitId", "title", "reason", "fitScore"],
        "properties": {
          "outfitId": { "type": "string" },
          "title": { "type": "string" },
          "reason": { "type": "string" },
          "fitScore": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      },
      "minItems": 1
    }
  }
}
